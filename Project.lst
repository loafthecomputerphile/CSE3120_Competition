 0000001B			IsLetterUsed PROC
 0000001B  60			    pushad                      ; saves EAX (= the caller's AL in the low byte)
				 
				    ; Normalize the query char to uppercase if it is a letter
 0000001C  8A C8		    mov cl, al
 0000001E  80 F9 61		    cmp cl, 'a'
 00000021  72 08		    jb  ILU_Scan
 00000023  80 F9 7A		    cmp cl, 'z'
 00000026  77 03		    ja  ILU_Scan
 00000028  80 E1 DF		    and cl, 11011111b           ; uppercase
				 
 0000002B			    ILU_Scan:
 0000002B  BE 00001DE1 R	        mov esi, OFFSET used_letters
 00000030			    ILU_Loop:
 00000030  8A 06		        mov al, [esi]
 00000032  3C 00		        cmp al, 0
 00000034  74 0E		        je  ILU_NotFound
				        ; The stored chars are already normalized (AddUsedLetter normalizes letters)
 00000036  3A C1		        cmp al, cl
 00000038  74 03		        je  ILU_Found
 0000003A  46			        inc esi
 0000003B  EB F3		        jmp ILU_Loop
				    
 0000003D			    ILU_Found:
 0000003D  61			        popad
 0000003E  A9 00000000		        test eax, 0     ; ZF = 1
 00000043  C3			        ret
				    
 00000044			    ILU_NotFound:
 00000044  61			        popad
 00000045  83 C8 01		        or  eax, 1      ; ZF = 0
 00000048  C3			        ret
 00000049			IsLetterUsed ENDP

 00000049			AddUsedLetter PROC
 00000049  60			    pushad
 0000004A  8A C8		    mov cl, al
				 
				    ; Normalize letters only
 0000004C  80 F9 61		    cmp cl, 'a'
 0000004F  72 08		    jb  ALU_Store
 00000051  80 F9 7A		    cmp cl, 'z'
 00000054  77 03		    ja  ALU_Store
 00000056  80 E1 DF		    and cl, 11011111b
				 
 00000059			    ALU_Store:
 00000059  BF 00001DE1 R	        mov edi, OFFSET used_letters
 0000005E  03 3D 00001E21 R	        add edi, used_count         ; point past existing chars
 00000064  88 0F		        mov [edi], cl               ; store new char
 00000066  47			        inc edi
 00000067  C6 07 00		        mov BYTE PTR [edi], 0       ; keep null-terminated
 0000006A  FF 05 00001E21 R	        inc used_count
				    
 00000070  61			        popad
 00000071  C3			        ret
 00000072			AddUsedLetter ENDP

