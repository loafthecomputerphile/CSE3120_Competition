				CMP_NOCASE MACRO char1, char2
				    LOCAL skip1, skip2
				    push eax
				    push ebx
				    ; Convert char1 to uppercase if it's a lowercase letter
				    cmp char1, 'a'
				    jb  skip1
				    cmp char1, 'z'
				    ja  skip1
				    and char1, 11011111b    ;; to uppercase (0xDF)
				    skip1:

				        ; Convert char2 to uppercase if it's a lowercase letter
				        cmp char2, 'a'
				        jb  skip2
				        cmp char2, 'z'
				        ja  skip2
				        and char2, 11011111b
				    skip2:
				        cmp char1, char2
				        pop ebx
				        pop eax
				ENDM
				;NEW MACRO
				WRITEMSG MACRO varName
				    mov edx, OFFSET varName     ; moved the offset of varName into edx
				    call WriteString            ; print the string
				ENDM

				; input: esi = pointer to string 1, edi = pointer to string 2
				; output: zf = 1 if match
 000003BE			Str_Compare_NOCASE PROC
 000003BE  60			    pushad              ; Save all registers

 000003BF			    L1:
 000003BF  8A 06		        mov al, [esi]      
 000003C1  8A 1F		        mov bl, [edi]       
				        
				        ; Convert AL to uppercase
 000003C3  3C 61		        cmp al, 'a'
 000003C5  72 06		        jb  CheckBL
 000003C7  3C 7A		        cmp al, 'z'
 000003C9  77 02		        ja  CheckBL
 000003CB  24 DF		        and al, 11011111b
 000003CD			    CheckBL:
				        ; Convert BL to uppercase
 000003CD  80 FB 61		        cmp bl, 'a'
 000003D0  72 08		        jb  CompareChars
 000003D2  80 FB 7A		        cmp bl, 'z'
 000003D5  77 03		        ja  CompareChars
 000003D7  80 E3 DF		        and bl, 11011111b

 000003DA			    CompareChars:
 000003DA  3A C3		        cmp al, bl      ; Compare normalized chars
 000003DC  75 0F		        jne NotEqual        ; If mismatch, exit
				        
 000003DE  3C 00		        cmp al, 0
 000003E0  74 04		        je  StringsMatch
				        
 000003E2  46			        inc esi
 000003E3  47			        inc edi
 000003E4  EB D9		        jmp L1

 000003E6			    StringsMatch:
 000003E6  61			        popad               ; Restore registers
 000003E7  A9 00000000		        test eax, 0         ; Force Zero Flag = 1
 000003EC  C3			        ret

 000003ED			    NotEqual:
 000003ED  61			        popad               ; Restore registers
 000003EE  83 C8 01		        or eax, 1           ; Force Zero Flag = 0
 000003F1  C3			        ret
 000003F2			Str_Compare_NOCASE ENDP


				; returns: EAX = random line index (0-based)
 000003F2			GetRandomFileLine PROC
				    ; 1. Open the file to count total lines
				    OPENFILECREATE
 000003F2  6A 00	   *	    push   +000000000h
 000003F4  6A 00	   *	    push   +000000000h
 000003F6  6A 03	   *	    push   +000000003h
 000003F8  6A 00	   *	    push   +000000000h
 000003FA  6A 01	   *	    push   +000000001h
 000003FC  68 80000000	   *	    push   +080000000h
 00000401  68 00000000 R   *	    push   OFFSET databaseName
 00000406  E8 00000000 E   *	    call   CreateFileA
 0000040B  A3 0000151F R	    mov file_handle, eax
 00000410  83 F8 FF		    cmp eax, INVALID_HANDLE_VALUE
 00000413  74 64		    je  Fail

 00000415  C7 05 0000151A R	    mov current_line, 0
	   00000000

 0000041F			    CountLoop:
				        OPENFILEREAD
 0000041F  6A 00	   *	    push   +000000000h
 00000421  68 00001523 R   *	    push   OFFSET bytes_read
 00000426  68 00001000	   *	    push   +000001000h
 0000042B  68 00000516 R   *	    push   OFFSET file_buffer
 00000430  FF 35 0000151F R *	    push   file_handle
 00000436  E8 00000000 E   *	    call   ReadFile
 0000043B  83 3D 00001523 R	        cmp bytes_read, 0
	   00
 00000442  74 1A		        je  EndCount
 00000444  8B 0D 00001523 R	        mov ecx, bytes_read
 0000044A  BE 00000516 R	        mov esi, OFFSET file_buffer

 0000044F			    Scan:
 0000044F  AC			        lodsb
 00000450  3C 0A		        cmp al, 0Ah          ; Line Feed found?
 00000452  75 06		        jne Next
 00000454  FF 05 0000151A R	        inc current_line
 0000045A			    Next:
 0000045A  E2 F3		        loop Scan
 0000045C  EB C1		        jmp CountLoop
 0000045E			    EndCount:
				        INVOKE CloseHandle, file_handle
 0000045E  FF 35 0000151F R *	    push   file_handle
 00000464  E8 00000000 E   *	    call   CloseHandle
 00000469  A1 0000151A R	        mov eax, current_line
 0000046E  83 F8 00		        cmp eax, 0
 00000471  74 06		        je  Fail
 00000473  E8 00000000 E	        call RandomRange     ; Returns [0 to current_line-1] in EAX
 00000478  C3			        ret
 00000479			    Fail:
 00000479  33 C0		        xor eax, eax
 0000047B  C3			        ret
				    
 0000047C			GetRandomFileLine ENDP


				; input: EAX = line index to retrieve
 0000047C			LoadFileLine PROC
 0000047C  A3 00001516 R	    mov target_line, eax
 00000481  C7 05 0000151A R	    mov current_line, 0
	   00000000
 0000048B  C6 05 0000151E R	    mov is_copying, 0
	   00
				    
				    OPENFILECREATE
 00000492  6A 00	   *	    push   +000000000h
 00000494  6A 00	   *	    push   +000000000h
 00000496  6A 03	   *	    push   +000000003h
 00000498  6A 00	   *	    push   +000000000h
 0000049A  6A 01	   *	    push   +000000001h
 0000049C  68 80000000	   *	    push   +080000000h
 000004A1  68 00000000 R   *	    push   OFFSET databaseName
 000004A6  E8 00000000 E   *	    call   CreateFileA
 000004AB  A3 0000151F R	    mov file_handle, eax
 000004B0  83 F8 FF		    cmp eax, INVALID_HANDLE_VALUE
 000004B3  74 79		    je  LoadExit

 000004B5  BF 00000116 R	    mov edi, OFFSET line_buffer

 000004BA			    ReadLoop:
				        OPENFILEREAD
 000004BA  6A 00	   *	    push   +000000000h
 000004BC  68 00001523 R   *	    push   OFFSET bytes_read
 000004C1  68 00001000	   *	    push   +000001000h
 000004C6  68 00000516 R   *	    push   OFFSET file_buffer
 000004CB  FF 35 0000151F R *	    push   file_handle
 000004D1  E8 00000000 E   *	    call   ReadFile
 000004D6  83 3D 00001523 R	        cmp bytes_read, 0
	   00
 000004DD  74 44		        je  CloseAndExit
				        
 000004DF  8B 0D 00001523 R	        mov ecx, bytes_read
 000004E5  BE 00000516 R	        mov esi, OFFSET file_buffer

 000004EA			    Process:
 000004EA  AC			        lodsb
 000004EB  8A D8		        mov bl, al
				        
 000004ED  8B 15 0000151A R	        mov edx, current_line
 000004F3  3B 15 00001516 R	        cmp edx, target_line
 000004F9  75 16		        jne Skip

				        ; We are at the target line
 000004FB  C6 05 0000151E R	        mov is_copying, 1
	   01
 00000502  80 FB 0D		        cmp bl, 0Dh          ; Carriage Return?
 00000505  74 19		        je  Finish
 00000507  80 FB 0A		        cmp bl, 0Ah          ; Line Feed?
 0000050A  74 14		        je  Finish
				        
 0000050C  88 1F		        mov [edi], bl        ; Copy char to line_buffer
 0000050E  47			        inc edi
 0000050F  EB 0B		        jmp NextChar

 00000511			    Skip:
 00000511  80 FB 0A		        cmp bl, 0Ah
 00000514  75 06		        jne NextChar
 00000516  FF 05 0000151A R	        inc current_line

 0000051C			    NextChar:
 0000051C  E2 CC		        loop Process
 0000051E  EB 9A		        jmp  ReadLoop

 00000520			    Finish:
 00000520  C6 07 00		        mov BYTE PTR [edi], 0 ; Null terminate
 00000523			    CloseAndExit:
				        INVOKE CloseHandle, file_handle
 00000523  FF 35 0000151F R *	    push   file_handle
 00000529  E8 00000000 E   *	    call   CloseHandle
 0000052E			    LoadExit:
 0000052E  C3			        ret
 0000052F			LoadFileLine ENDP


